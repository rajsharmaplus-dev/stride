# VM Deployment — Environment Template
# Copy this to .env on the VM and fill in SESSION_SECRET
# DO NOT commit the actual .env file (it is gitignored)

NODE_ENV=production
PORT=9090

# Local PostgreSQL (running on the VM, reached via Docker bridge gateway)
DATABASE_URL=postgresql://stride_user:StrideVm2024!@host.docker.internal:5432/stride_db

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=801131875690-fb46e9k4i8qd6h6apqtvmpjfl6aae6hg.apps.googleusercontent.com

# Session Secret — generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32
